# ══════════════════════════════════════════════════════════════
# DRIZZLE — .env Configuration
# ══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# The .env file must be at: /Drizzle_Guidewire/.env  (project root)
# ══════════════════════════════════════════════════════════════


# ── Database (Supabase) ────────────────────────────────────────
#
# HOW TO GET THIS FROM SUPABASE:
#   1. Go to https://supabase.com/dashboard → your project
#   2. Click "Settings" (gear icon) → "Database"
#   3. Scroll to "Connection string" section
#   4. Select the "URI" tab
#   5. Copy the string — it looks like:
#        postgres://postgres.xxxx:PASSWORD@aws-0-ap-south-1.pooler.supabase.com:6543/postgres
#
# THEN CHANGE TWO THINGS:
#   • Replace  "postgres://"  →  "postgresql+asyncpg://"
#   • Append   "?sslmode=require"  at the end
#
# TRANSACTION MODE (port 6543) — use this for most setups:
DATABASE_URL=postgresql+asyncpg://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?sslmode=require

# SESSION MODE (port 5432) — alternative if you get pooler errors:
# DATABASE_URL=postgresql+asyncpg://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-ap-south-1.pooler.supabase.com:5432/postgres?sslmode=require


# ── Supabase API (optional — for direct Supabase client use) ──
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key-from-supabase-api-settings


# ── JWT Auth ──────────────────────────────────────────────────
# Change this to any long random string in production
JWT_SECRET_KEY=drizzle-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24


# ── External API Keys (optional — needed for live risk scoring) ─
WEATHERAPI_KEY=your-weatherapi-key
TOMTOM_API_KEY=your-tomtom-key
NEWSAPI_KEY=your-newsapi-key
OPENAI_API_KEY=your-openai-key


# ── MCP Servers (leave as-is for local dev) ───────────────────
WEATHER_MCP_URL=http://127.0.0.1:8001/score
TRAFFIC_MCP_URL=http://127.0.0.1:8002/score
SOCIAL_MCP_URL=http://127.0.0.1:8003/score


# ── Server ────────────────────────────────────────────────────
PORT=8000
DEBUG=false
